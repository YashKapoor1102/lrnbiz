{
  "version": "1.2",
  "module": "niche_validator",
  "description": "Deterministic niche validation rules — ITS Stage 2: Idea & Target Extraction. Rules are evaluated in order; first error blocks progress.",
  "rules": [
    {
      "id": "NR010",
      "name": "Inappropriate or harmful content",
      "type": "blacklist",
      "terms": [
        "sell sex", "selling sex", "sex work", "sex service", "sexual service", "sexual services",
        "sell sex", "buy sex", "sex for sale", "sex for money", "sex as a service",
        "prostitution", "escort service", "escort business", "brothel", "strip club", "stripper",
        "sell nude", "nude photos", "nude pictures", "nude images", "sell nudes",
        "adult entertainment", "adult content", "adult services", "adult industry",
        "erotic", "erotica", "pornography", "porn site", "porn business", "sell porn",
        "onlyfans", "only fans",
        "fuck", "fucking", "fucker", "motherfucker", "motherfucking",
        "shit business", "bullshit business",
        "sell drugs", "selling drugs", "deal drugs", "drug dealing", "drug dealer", "drug deal",
        "sell weed", "selling weed", "sell marijuana", "sell cannabis", "sell cocaine",
        "sell heroin", "sell meth", "sell crack", "sell ecstasy", "sell mdma",
        "sell pills", "sell prescription", "sell opioids",
        "sell weapons", "selling weapons", "sell guns", "selling guns", "sell firearms",
        "sell knives", "sell bombs", "sell explosives", "sell ammunition",
        "illegal weapons", "black market",
        "kill people", "killing people", "murder service", "hire a hitman", "assassination",
        "sell poison", "selling poison",
        "hack people", "hacking service", "sell malware", "sell ransomware", "sell exploits",
        "steal from", "robbery service", "scam people", "scam business", "ponzi",
        "sell humans", "human trafficking", "trafficking"
      ],
      "severity": "error",
      "flag": "inappropriate_content",
      "message": "This content is not appropriate for a school business platform. Please describe a real, legal, school-safe business idea.",
      "socratic_hint": "The student has described something inappropriate, illegal, or harmful. Do not engage with the content — simply tell them this is not suitable for a school platform and ask them to think of a real business idea they could run safely."
    },
    {
      "id": "NR015",
      "name": "Disrespectful language toward customers",
      "type": "blacklist",
      "terms": [
        "stupid", "idiots", "idiot", "morons", "moron", "imbecile", "imbeciles",
        "dimwit", "dimwits", "dunce", "dunces", "retard", "retards",
        "dumb people", "dumb students", "dumb kids", "dumb customers", "dumb users",
        "for dummies", "dumbass", "dumbasses",
        "for losers", "loser students", "loser customers", "loser people",
        "useless people", "useless students", "useless customers",
        "clueless people", "clueless students", "clueless customers", "clueless users",
        "hopeless students", "hopeless people", "hopeless customers",
        "thick people", "thick students", "thick customers",
        "brainless", "braindead", "mindless people", "mindless customers",
        "pathetic people", "pathetic students", "pathetic customers",
        "wasting my time", "waste of time customers",
        "bad at learning", "bad at studying", "bad at maths", "bad at math",
        "can't learn", "cannot learn", "too dumb to", "too stupid to",
        "not smart enough", "not clever enough", "intellectually challenged"
      ],
      "severity": "warning",
      "flag": "disrespectful_language",
      "message": "Your description uses language that could come across as disrespectful toward your customers. Customers need to feel valued — rephrase to describe the problem they face, not a judgement about them.",
      "socratic_hint": "The student used a derogatory term to describe their target customers. Ask them: how would a customer feel if they read this description? What problem does this customer actually have that you could solve — without judging them?"
    },
    {
      "id": "NR001",
      "name": "Too short",
      "type": "min_length",
      "threshold": 30,
      "severity": "error",
      "flag": "too_short",
      "message": "Too short to be specific — write at least a sentence.",
      "socratic_hint": "The student's description is too short. Ask them to expand: who exactly is this person, where do they encounter the problem, and what specifically do they need or struggle with?"
    },
    {
      "id": "NR002",
      "name": "Vague mass-market term",
      "type": "blacklist",
      "terms": [
        "everyone", "everyone who", "anyone", "anyone who", "everybody",
        "all people", "all ages", "anybody", "the public", "general public",
        "all customers", "whole market", "most people", "lots of people",
        "many people", "people everywhere", "any customer", "any person",
        "the masses", "all students", "all teens",
        "all users", "all people who", "all customers who",
        "everyone who signs up", "anyone who needs this", "all people who need",
        "all players", "all gamers", "all roblox", "all minecraft", "all fortnite",
        "players everywhere", "gamers everywhere", "users everywhere",
        "millions of players", "millions of users", "hundreds of millions",
        "billions of", "all over the world", "worldwide market", "global market",
        "all kids", "all children", "all adults", "all families",
        "all businesses", "all schools", "all companies",
        "the whole world", "every person", "every student", "every gamer",
        "every player", "every user", "every kid", "every child",
        "all genders", "all backgrounds", "all walks of life",
        "universal", "mass market", "anyone can", "everyone can",
        "all age groups", "entire market", "entire population",
        "global audience", "international market", "all countries"
      ],
      "severity": "error",
      "flag": "vague_audience",
      "message": "Words like 'everyone' or 'all ages' describe no one — a real niche must exclude someone.",
      "socratic_hint": "The student used a vague mass-market term. Challenge them: who would NOT be your customer? Push them to name who benefits most specifically — a niche that serves everyone serves no one."
    },
    {
