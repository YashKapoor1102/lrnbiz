        "teen", "teens", "teenager", "teenagers", "senior", "seniors", "child", "children",
        "kid", "kids", "baby", "babies", "toddler", "toddlers", "elderly", "youth",
        "adult", "adults", "woman", "women", "man", "men", "female", "male",
        "owner", "owners", "mom", "moms", "dad", "dads", "mother", "mothers", "father", "fathers",
        "runner", "runners", "athlete", "athletes", "gamer", "gamers", "chef", "chefs",
        "artist", "artists", "musician", "musicians", "entrepreneur", "entrepreneurs",
        "freelancer", "freelancers", "who are", "who have", "who need", "who want",
        "who use", "who like", "who love", "who struggle", "who buy", "who wear",
        "families", "couples", "retirees", "commuter", "commuters", "small business",
        "who can't", "who don't", "who spend", "people in grade", "high school", "middle school",
        "for teens", "for students", "for kids", "for adults", "for parents", "for women",
        "for men", "for seniors", "for girls", "for boys", "for gamers", "for athletes",
        "for runners", "for artists", "for teachers", "girl", "girls", "boy", "boys",
        "classmate", "classmates", "friends who", "peer", "peers",
        "gym", "school", "office", "local", "neighbourhood", "community"
      ],
      "severity": "error",
      "flag": "missing_who",
      "message": "No specific person type — name an age group, role, interest, or life situation.",
      "socratic_hint": "The student hasn't defined WHO the customer is. Probe: is there an age range, profession, life stage, or interest that defines this person specifically? Push for a concrete human being, not an abstraction."
    },
    {
